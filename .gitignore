# Git ignore for cardiac-digital-twin

# MATLAB generated files
*.asv
*.mex*
slprj/
*.slxc
*.slxp

# Simulink editor / autosave / temp
*.autosave
*~mdl.slmx
*_harnessInfo.xml

# Simulink model file — excluded; generated programmatically by create_cardiac_model.m
CardiacDigitalTwin.slx
CardiacDigitalTwin.slxc

# MATLAB workspace data
*.mat

# Figure exports
*.fig
*.png
*.jpg

# But: do track the README / docs images intentionally committed under docs/images/
!docs/images/*.png
!docs/images/*.jpg

# OS files
.DS_Store
Thumbs.db
desktop.ini

# VS Code local settings (mcp.json is intentionally tracked)
.vscode/settings.json
.vscode/launch.json

# MkDocs build output
site/
